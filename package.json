{
  "name": "@antelopejs/stripe",
  "version": "1.0.0",
  "description": "A flexible payment module that implements the Stripe interface of antelopejs",
  "keywords": [
    "antelopejs",
    "stripe",
    "payment",
    "billing",
    "checkout"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/stripe.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "test": "echo \"No test specified\""
  },
  "antelopeJs": {
    "implements": [
      "@antelopejs/interface-stripe"
    ],
    "defaultConfig": {
      "apiKey": "your_stripe_api_key",
      "webhookSecret": "your_stripe_webhook_secret",
      "endpoint": "stripe"
    }
  },
  "dependencies": {
    "@antelopejs/interface-api": "^0.0.2",
    "@antelopejs/interface-redis": "^0.0.2",
    "@antelopejs/interface-stripe": "^0.0.2",
    "ioredis": "^5.10.0",
    "stripe": "^18.0.0",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/node": "^22.14.1",
    "@types/uuid": "10.0.0",
    "release-it": "^19.2.4",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}
